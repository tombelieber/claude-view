{
  "name": "@claude-view/plugin",
  "version": "0.26.1",
  "description": "Claude Code plugin for claude-view — auto-starts web dashboard, provides session/cost/fluency tools and skills",
  "private": false,
  "type": "module",
  "files": [".claude-plugin/", ".mcp.json", "skills/", "hooks/", "dist/", "README.md"],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test src/__tests__/ && bash scripts/validate-plugin.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "@types/node": "^22"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "claude-view",
    "mission-control",
    "session-analytics",
    "cost-tracking"
