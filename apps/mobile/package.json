{
  "name": "@claude-view/mobile",
  "version": "0.14.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "npx expo start --dev-client",
    "dev:clear": "npx expo start -c --dev-client",
    "build:ios": "eas build --platform ios",
    "build:ios:sim": "EAS_NO_VCS=1 eas build --local --platform ios --profile development-simulator",
    "build:ios:dev": "EAS_NO_VCS=1 eas build --local --platform ios --profile development",
    "build:android": "eas build --platform android",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claude-view/design-tokens": "workspace:*",
    "@claude-view/shared": "workspace:*",
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/native": "^7.1.28",
    "@tamagui/config": "^2.0.0-rc.18",
    "@tamagui/font-inter": "^2.0.0-rc.18",
    "expo": "~55.0.5",
    "expo-camera": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.0",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "lucide-react-native": "^0.575.0",
    "onesignal-expo-plugin": "^2.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-onesignal": "^5.3.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tamagui": "^2.0.0-rc.18",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@tamagui/babel-plugin": "^2.0.0-rc.18",
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  }
}
