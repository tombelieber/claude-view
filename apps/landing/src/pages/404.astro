---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Page Not Found">
  <section class="min-h-[60vh] flex flex-col items-center justify-center px-6 text-center">
    <h1 class="font-heading text-6xl font-bold text-slate-500 mb-4">404</h1>
    <p class="text-xl text-slate-400 mb-8">This page doesn't exist. Maybe it was moved?</p>
    <a href="/" class="inline-block px-6 py-3 bg-green-600 text-white rounded-lg font-medium hover:bg-green-500 transition-colors">
      Back to Home
    </a>
  </section>
</MarketingLayout>
