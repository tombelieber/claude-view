# .env.example — copy to .env.local (gitignored) for dev-only config.
#
# scripts/dev.sh and scripts/dev-server.sh source .env.local if it exists.
# All values here are OPTIONAL; unset values disable the related feature.

# ─── Share worker ────────────────────────────────────────────────────────
# End-to-end encrypted conversation sharing.
# If unset, the share button is hidden in the UI and /share routes 501.
# Ask a maintainer for dev URLs.
SHARE_WORKER_URL=
SHARE_VIEWER_URL=

# ─── Overrides (already defaulted in dev.sh) ─────────────────────────────
# Uncomment and set to override the defaults baked into dev.sh.
# RUST_LOG=debug,claude_view_server=trace
# VITE_PORT=5174
# SUPABASE_URL=https://your-project.supabase.co
