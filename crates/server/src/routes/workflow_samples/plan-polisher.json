{
  "id": "plan-polisher",
  "name": "Plan Polisher",
  "description": "Audits a plan until it scores 100/100 on prove-it",
  "author": "official",
  "category": "Development",
  "version": "1.0.0",
  "inputs": [
    {
      "name": "plan_file",
      "type": "file",
      "description": "Path to the implementation plan MD file"
    }
  ],
  "defaults": {
    "model": "claude-opus-4-6",
    "permissionMode": "default",
    "settingSources": ["user", "project"],
    "effort": "max",
    "maxBudgetUsd": 20.0,
    "maxTurns": 200
  },
  "nodes": [
    {
      "id": "input-0",
      "type": "workflowInput",
      "position": { "x": 0, "y": 0 },
      "data": { "label": "plan_file" }
    },
    {
      "id": "stage-audit",
      "type": "workflowStage",
      "position": { "x": 300, "y": 0 },
      "data": {
        "label": "Audit Plan",
        "prompt": "Run /prove-it on the plan at {{plan_file}}. If verdict is not PASS, fix issues and re-audit.",
        "model": "opus",
        "tools": ["Read", "Write", "Edit", "Bash", "Grep", "Glob"],
        "skills": ["/auditing-plans", "/prove-it"],
        "maxTurns": 100,
        "gate": {
          "type": "json_field",
          "field": "verdict",
          "operator": "equals",
          "value": "PASS",
          "maxRetries": 3
        }
      }
    },
    {
      "id": "done-0",
      "type": "workflowDone",
      "position": { "x": 600, "y": 0 },
      "data": { "label": "Done" }
    }
  ],
  "edges": [
    { "id": "e-input-audit", "source": "input-0", "target": "stage-audit" },
    { "id": "e-audit-done", "source": "stage-audit", "target": "done-0" }
  ]
}
