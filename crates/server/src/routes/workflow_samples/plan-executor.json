{
  "id": "plan-executor",
  "name": "Plan Executor",
  "description": "Implements a polished plan and ships it as a PR",
  "author": "official",
  "category": "Development",
  "version": "1.0.0",
  "inputs": [
    {
      "name": "plan_file",
      "type": "file",
      "description": "Path to the polished implementation plan MD file"
    }
  ],
  "defaults": {
    "model": "claude-opus-4-6",
    "permissionMode": "default",
    "settingSources": ["user", "project"],
    "effort": "max",
    "maxBudgetUsd": 50.0,
    "maxTurns": 500
  },
  "nodes": [
    {
      "id": "input-0",
      "type": "workflowInput",
      "position": { "x": 0, "y": 0 },
      "data": { "label": "plan_file" }
    },
    {
      "id": "stage-implement",
      "type": "workflowStage",
      "position": { "x": 300, "y": 0 },
      "data": {
        "label": "Implement Plan",
        "prompt": "Implement the plan at {{plan_file}} using subagent-driven development.",
        "model": "opus",
        "tools": ["Read", "Write", "Edit", "Bash", "Grep", "Glob", "Agent"],
        "skills": ["/feature-dev:feature-dev", "/subagent-driven-development"],
        "maxTurns": 300
      }
    },
    {
      "id": "stage-ship",
      "type": "workflowStage",
      "position": { "x": 600, "y": 0 },
      "data": {
        "label": "Ship as PR",
        "prompt": "Run /shippable on the completed implementation. If verdict is not SHIP IT, fix issues.",
        "model": "opus",
        "tools": ["Read", "Write", "Edit", "Bash", "Grep", "Glob"],
        "skills": ["/shippable", "/commit-push-pr"],
        "maxTurns": 100,
        "gate": {
          "type": "regex",
          "pattern": "SHIP IT",
          "maxRetries": 3
        }
      }
    },
    {
      "id": "done-0",
      "type": "workflowDone",
      "position": { "x": 900, "y": 0 },
      "data": { "label": "Done" }
    }
  ],
  "edges": [
    { "id": "e-input-impl", "source": "input-0", "target": "stage-implement" },
    { "id": "e-impl-ship", "source": "stage-implement", "target": "stage-ship" },
    { "id": "e-ship-done", "source": "stage-ship", "target": "done-0" }
  ]
}
