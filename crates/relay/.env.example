# Relay server env vars — set via Fly.io secrets or shell exports.
# This file exists only as documentation for contributors.
#
# PORT=8080                              # Fly.io sets this automatically
# RUST_LOG=warn,claude_view_relay=info

# OneSignal push notifications (optional — push disabled if not set)
# ONESIGNAL_APP_ID=your-onesignal-app-id
# ONESIGNAL_REST_API_KEY=your-rest-api-key

# Sentry error tracking (optional — error reporting disabled if not set)
# SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# PostHog analytics (optional — event tracking disabled if not set)
# POSTHOG_API_KEY=phc_your-posthog-api-key

# Supabase JWT validation (optional — auth disabled if not set)
# SUPABASE_URL=https://your-project.supabase.co
